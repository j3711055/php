# ══════════════════════════════════════════════════════
#  OneIQ — Environment Variables Example
#  Copy this file to .env for local development.
#  On Railway: set these in the Railway dashboard (Variables tab).
#  ⚠️  NEVER commit your real .env file to Git!
# ══════════════════════════════════════════════════════

# ── Security (CHANGE BOTH BEFORE DEPLOYING) ───────────
# Strong random token used as Bearer token for admin API calls.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Admin panel login password
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Database ───────────────────────────────────────────
# Path to the SQLite database file.
# On Railway: set to /data/oneiq.sqlite (Railway Volume mount point)
# Locally:    leave as default or use ./database/oneiq.sqlite
SQLITE_DB_PATH=/data/oneiq.sqlite

# ── Application ───────────────────────────────────────
# Set to "production" on Railway to enable strict CORS and error suppression.
# Set to "development" locally to see detailed errors.
APP_ENV=production

# ── Port ──────────────────────────────────────────────
# Railway sets this automatically. DO NOT set this manually on Railway.
# For local Docker testing: docker run -p 8080:8080 ...
# PORT=8080
