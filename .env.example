# ══════════════════════════════════════════════════════
#  OneIQ — Environment Variables Example
#  Copy this file to .env for local development.
#  On Railway: set these in the dashboard (Variables tab).
#  ⚠️  NEVER commit your real .env file to Git!
# ══════════════════════════════════════════════════════

# ── Security (CHANGE BOTH BEFORE DEPLOYING) ───────────
# Generate ADMIN_TOKEN with:  openssl rand -hex 32
ADMIN_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── MySQL Database ─────────────────────────────────────
# On Railway: these are set AUTOMATICALLY by the MySQL plugin.
# You do NOT need to set them manually if you add the MySQL plugin.
#
# Option A — Full URL (Railway sets this as MYSQL_URL):
# MYSQL_URL=mysql://root:password@containers-us-west-xxx.railway.app:6541/railway
#
# Option B — Individual variables (also set by Railway MySQL plugin):
# MYSQLHOST=containers-us-west-xxx.railway.app
# MYSQLPORT=6541
# MYSQLUSER=root
# MYSQLPASSWORD=your-password
# MYSQLDATABASE=railway
#
# For local development with a local MySQL server:
MYSQLHOST=127.0.0.1
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=oneiq

# ── Application ───────────────────────────────────────
# Set to "production" on Railway.
# Set to "development" locally to see detailed PHP errors.
APP_ENV=production

# ── Port ──────────────────────────────────────────────
# Railway sets this automatically. DO NOT set on Railway.
# For local Docker testing only:
# PORT=8080
