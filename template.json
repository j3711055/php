{
  "$schema": "https://railway.app/template.schema.json",
  "displayName": "واحد العراق — OneIQ PHP Streaming",
  "description": "Arabic sports streaming platform. PHP 8.3 + MySQL + Nginx. Live match dashboard, secure admin panel, referer-stripping stream gateway.",
  "tags": ["php", "mysql", "nginx", "arabic", "streaming", "sports"],
  "icon": "https://cdn.jsdelivr.net/gh/a9ii/MTProxy-Installer-Manager/images/oneIQ.webp",
  "readme": "https://raw.githubusercontent.com/YOUR_USERNAME/oneiq/main/README.md",
  "services": [
    {
      "name": "OneIQ App",
      "description": "PHP 8.3 + Nginx web application",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "startCommand": "/bin/sh /entrypoint.sh",
        "healthcheckPath": "/health.php",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
      },
      "variables": [
        {
          "name": "ADMIN_TOKEN",
          "description": "Bearer token for admin API. Auto-generated — copy and save it.",
          "required": true,
          "isSecret": true,
          "defaultValue": "${{ secret(64) }}"
        },
        {
          "name": "ADMIN_PASSWORD",
          "description": "Password for the admin dashboard at /goal. Auto-generated — copy and save it.",
          "required": true,
          "isSecret": true,
          "defaultValue": "${{ secret(24) }}"
        },
        {
          "name": "APP_ENV",
          "description": "Application environment. Keep as 'production' on Railway.",
          "required": false,
          "defaultValue": "production"
        }
      ]
    },
    {
      "name": "MySQL",
      "description": "MySQL 8.0 database",
      "type": "mysql"
    }
  ]
}
